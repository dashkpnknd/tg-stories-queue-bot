BOT_TOKEN=replace_me
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=replace_me

# Comma-separated Telegram user IDs allowed to manage the bot.
# Empty means anyone can use the bot.
ADMIN_IDS=

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_me

DATABASE_PATH=./data/bot.sqlite3
MEDIA_DIR=./data/media
PUBLISH_CHECK_SECONDS=60

# Optional proxy for Telethon user sessions (QR login, account auth, stories).
# Example: http://user:password@127.0.0.1:8000
TELETHON_PROXY_URL=

# Optional local Bot API endpoint. Leave empty to use api.telegram.org.
BOT_API_BASE_URL=
